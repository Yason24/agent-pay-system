<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the requested path exists as a real file or directory, serve it directly.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Otherwise send all requests to front controller.
    RewriteRule ^ index.php [L,QSA]
</IfModule>

DirectoryIndex index.php

